{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "group:allNonMajor",
    ":semanticCommitTypeAll(chore)",
    ":enableVulnerabilityAlertsWithLabel(security)"
  ],
  "timezone": "Europe/Paris",
  "labels": [
    "dependencies",
    "renovate"
  ],
  "pre-commit": {
    "enabled": true
  },
  "rebaseWhen": "conflicted",
  "packageRules": [
    {
      "description": "OpenTofu/Terraform version is governed by .tool-versions; do not bump required_version blocks independently.",
      "matchManagers": ["terraform"],
      "matchDepTypes": ["required_version"],
      "enabled": false
    },
    {
      "description": "3rd-party Rails ecosystem gems major-coupled to Rails. The 'Ruby on Rails packages' name matches group:rubyOnRails (auto-applied via config:best-practices) so these land in the same PR as the official rails/* gems.",
      "groupName": "Ruby on Rails packages",
      "matchManagers": ["bundler"],
      "matchPackageNames": ["sprockets-rails", "turbo-rails", "stimulus-rails", "rails-i18n"]
    },
    {
      "groupName": "hashicorp terraform providers",
      "matchDatasources": ["terraform-provider"],
      "matchPackageNames": ["/^hashicorp//"]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "prek (no asdf plugin upstream)",
      "managerFilePatterns": ["/(^|/)\\.tool-versions$/"],
      "matchStrings": ["prek (?<currentValue>\\S+)"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "j178/prek",
      "extractVersionTemplate": "^v?(?<version>.+)$"
    },
    {
      "customType": "regex",
      "description": "vite-plus (no asdf plugin upstream)",
      "managerFilePatterns": ["/(^|/)\\.tool-versions$/"],
      "matchStrings": ["vp (?<currentValue>\\S+)"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "voidzero-dev/vite-plus",
      "extractVersionTemplate": "^v?(?<version>.+)$"
    },
    {
      "customType": "regex",
      "description": "git-cliff (no asdf plugin upstream)",
      "managerFilePatterns": ["/(^|/)\\.tool-versions$/"],
      "matchStrings": ["git-cliff (?<currentValue>\\S+)"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "orhun/git-cliff",
      "extractVersionTemplate": "^v?(?<version>.+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)Dockerfile$/"],
      "matchStrings": ["ARG NODE_VERSION=(?<currentValue>\\S+)"],
      "datasourceTemplate": "node-version",
      "depNameTemplate": "node"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)Dockerfile$/"],
      "matchStrings": ["ARG BUN_VERSION=(?<currentValue>\\S+)"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "oven-sh/bun",
      "extractVersionTemplate": "^bun-v?(?<version>.+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)Dockerfile$/"],
      "matchStrings": ["npm install -g yarn@(?<currentValue>[0-9.]+)"],
      "datasourceTemplate": "npm",
      "depNameTemplate": "yarn"
    }
  ]
}
