{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "group:allNonMajor",
    ":semanticCommitTypeAll(chore)",
    ":enableVulnerabilityAlertsWithLabel(security)"
  ],
  "timezone": "Europe/Paris",
  "labels": [
    "dependencies",
    "renovate"
  ],
  "pre-commit": {
    "enabled": true
  },
  "packageRules": [
    {
      "description": "OpenTofu/Terraform version is governed by .tool-versions; do not bump required_version blocks independently.",
      "matchManagers": ["terraform"],
      "matchDepTypes": ["required_version"],
      "enabled": false
    },
    {
      "groupName": "hashicorp terraform providers",
      "matchDatasources": ["terraform-provider"],
      "matchPackageNames": ["/^hashicorp//"]
    },
    {
      "groupName": "bun",
      "matchDatasources": ["npm", "github-releases", "docker"],
      "matchPackageNames": ["bun", "oven-sh/bun", "/(^|/)oven/bun$/"]
    },
    {
      "groupName": "ruby",
      "matchDatasources": ["ruby-version"]
    },
    {
      "description": "Keep the whole Vite+ toolchain version in one PR: the `vp` pin in .tool-versions (github-releases voidzero-dev/vite-plus), the `vite-plus` npm devDep, and the `@voidzero-dev/vite-plus-core` package aliased by the `overrides.vite` entry. These are the same version expressed three ways; bumping them in separate PRs makes the standalone-vite/core Plugin types diverge (vp check TS2321/TS2769) and mismatches rolldown's native binding.",
      "groupName": "vite-plus",
      "matchPackageNames": ["voidzero-dev/vite-plus", "vite-plus", "@voidzero-dev/vite-plus-core"]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "prek (no asdf plugin upstream)",
      "managerFilePatterns": ["/(^|/)\\.tool-versions$/"],
      "matchStrings": ["prek (?<currentValue>\\S+)"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "j178/prek",
      "extractVersionTemplate": "^v?(?<version>.+)$"
    },
    {
      "customType": "regex",
      "description": "vite-plus (no asdf plugin upstream)",
      "managerFilePatterns": ["/(^|/)\\.tool-versions$/"],
      "matchStrings": ["vp (?<currentValue>\\S+)"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "voidzero-dev/vite-plus",
      "extractVersionTemplate": "^v?(?<version>.+)$"
    },
    {
      "customType": "regex",
      "description": "git-cliff (no asdf plugin upstream)",
      "managerFilePatterns": ["/(^|/)\\.tool-versions$/"],
      "matchStrings": ["git-cliff (?<currentValue>\\S+)"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "orhun/git-cliff",
      "extractVersionTemplate": "^v?(?<version>.+)$"
    },
    {
      "customType": "regex",
      "description": "bun via package.json `packageManager` field (Renovate's npm manager skips bun here — verified against renovate main 2026-05-20)",
      "managerFilePatterns": ["/(^|/)package\\.json$/"],
      "matchStrings": ["\"packageManager\"\\s*:\\s*\"bun@(?<currentValue>[^\"]+)\""],
      "datasourceTemplate": "npm",
      "depNameTemplate": "bun"
    }
  ]
}
